---
const services = [
  {
    title: "Video Production",
    description: "Professional video content from concept to delivery. We handle scripting, filming, editing, and post-production with broadcast-quality results.",
    icon: "🎬"
  },
  {
    title: "Streaming Solutions",
    description: "Live event streaming and platform setup that just works. From conferences to product launches, we manage the entire technical stack.",
    icon: "📡"
  },
  {
    title: "Podcast Production",
    description: "Full-service podcast production from recording to distribution. We handle editing, mixing, show notes, RSS hosting, and submission to all major platforms.",
    icon: "🎙️"
  },
  {
    title: "Media Consulting",
    description: "Strategic guidance and workflow optimization for content creators and businesses. We make media production scalable and efficient.",
    icon: "💡"
  }
];
---

<section id="services" class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <h2 class="text-4xl font-bold text-center mb-16 text-gray-900">Our Services</h2>
    <div class="grid md:grid-cols-2 gap-12">
      {services.map((service) => (
        <div class="bg-gray-50 p-8 rounded-lg hover:shadow-lg transition-shadow">
          <div class="text-5xl mb-4">{service.icon}</div>
          <h3 class="text-2xl font-bold mb-4 text-gray-900">{service.title}</h3>
          <p class="text-gray-700 leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
